void updateTimer() {
  static unsigned long lastUpdate = 0;

  static bool wasRunning = false;
  if (isRunning && !wasRunning) {
      lastUpdate = millis();
      wasRunning = true;
  }
  if (!isRunning) wasRunning = false;
  if (isRunning && (millis() - lastUpdate) > TIMER_UPDATE_INTERVAL) {
    lastUpdate = millis();
    remainingSeconds--;
    if (remainingSeconds <= 0) { remainingSeconds = totalSeconds; isRunning = false; }
    drawTimer();
  }
}
