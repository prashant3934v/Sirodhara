void initializeWifi(const char* newSSID = NULL, const char* newPassword = NULL, bool isOpen = false) {
  Serial.println("Initializing WiFi...");
  bool isNew = (newSSID != NULL);
  WiFi.mode(WIFI_STA);

  if (isNew) {
    Serial.print("Connecting to new network: ");
    Serial.println(newSSID);
    WiFi.begin(newSSID, newPassword);
  } else {
    preferences.begin("wifi", true);
    String savedSSID = preferences.getString("ssid", "shirodhara");
    String savedPassword = preferences.getString("password", "12345678");
    bool savedIsOpen = preferences.getBool("isOpen", false);
    preferences.end();
    
    Serial.print("Connecting to saved network: ");
    Serial.println(savedSSID);
    if (savedIsOpen) {
      WiFi.begin(savedSSID);
    } else {
      WiFi.begin(savedSSID, savedPassword);
    }
  }
  int attempts = 0;
  while (WiFi.status() != WL_CONNECTED && attempts < 20) {
    delay(500);
    attempts++;
    Serial.print(".");
  }
 if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\n✓ WiFi connected");
    Serial.println(WiFi.localIP());
    if (isNew) {
      preferences.begin("wifi", false);
      preferences.putString("ssid", newSSID);
      preferences.putString("password", newPassword != NULL ? newPassword : "");
      preferences.putBool("isOpen", isOpen);
      preferences.end();
      Serial.println("✓ New WiFi credentials saved");
    }
  } else {
    Serial.println("\n✗ WiFi connection FAILED!");
  }
}

