void startMotor2Move(int rotations) {
  motor2StepsRemaining = abs(rotations) * PULSES_PER_REV;
  motor2Dir = rotations > 0;

  digitalWrite(DIR_PIN_2, motor2Dir ? HIGH : LOW);
}

void runMotor2() {
  if (motor2StepsRemaining <= 0) return;

  unsigned long now = micros();

  if (now - lastMotor2StepTime >= motor2SpeedDelay) {
    lastMotor2StepTime = now;

    digitalWrite(STEP_PIN_2, HIGH);
    delayMicroseconds(2);
    digitalWrite(STEP_PIN_2, LOW);

    motor2StepsRemaining--;
  }
}

