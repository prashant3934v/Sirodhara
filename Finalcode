}

void syncTime() {
  if(WiFi.status() != WL_CONNECTED) {
    Serial.println("Cannot sync time: WiFi not connected");
    return;
  }
  configTime(0, 0, "pool.ntp.org","time.google.com");

  struct tm timeinfo;
  int retry = 0;
  const int maxRetry = 5;

  while (!getLocalTime(&timeinfo) && retry < maxRetry) {
    retry++;
    Serial.println(".");
    delay(500);
  }
  lastSyncMillis = millis();
}

long long getEpochMillis() {
  struct timeval tv;
  gettimeofday(&tv, NULL);
  return (long long)tv.tv_sec * 1000LL + tv.tv_usec / 1000;
}


// ==================== BLE DATA FUNCTIONS ====================
String createDataPacket(bool sendAll = true) {
  uint16_t flags = sendAll ? FLAG_ALL : bitFlag;
  JsonDocument doc; 
  if(flags & FLAG_TIMER){
    JsonObject timer = doc["tm"].to<JsonObject>();

    unsigned long timeSinceSync = millis() - lastSyncMillis;
    if (lastSyncMillis > 0 && timeSinceSync < SIX_HOURS_MS) {
      timer["ts"] = getEpochMillis();
    }
    timer["run"] = isRunning;
    timer["tt"] = totalSeconds;
    timer["rm"] = remainingSeconds;
  }  
  
  if(flags & (FLAG_FLOW_CHANGED | FLAG_ANGLE_CHANGED | FLAG_SPEED_CHANGED)) {
    JsonObject status = doc["st"].to<JsonObject>();
    if(flags & FLAG_FLOW_CHANGED) status["f"] = flow;
    if(flags & FLAG_ANGLE_CHANGED) status["a"] = angle;
    if(flags & FLAG_SPEED_CHANGED) status["s"] = speed;
  }
  if(flags & FLAG_TEMPERATURE) {
    JsonObject tempObj = doc["extra"].to<JsonObject>();
    tempObj["t"] = currentTemp;
  }
  if(flags & FLAG_INBUILT) {
    JsonObject status = doc["st"].to<JsonObject>();
    status["f"] = flow;
    status["a"] = angle;
    status["s"] = speed;
    doc["inbuilt"] = inbuiltFluidIndex;
  }
  String buffer;
  serializeJson(doc, buffer);
  Serial.printf("Sending packet: %s\n", buffer.c_str());
  return buffer;
}

void sendData(bool sendAll = false) {
  if (!deviceConnected) return;
  String packet = createDataPacket(sendAll);
  wsServer.sendTXT(connectedID, packet);
  if (sendAll) {
    lastSync  = millis();
  }
  
  bitFlag = 0;
}

// ==================== JSON & WS EVENT HANDLING ====================
bool updateFromJson(const String& json) {
  // Use Static to save heap fragmentation
  JsonDocument doc;
  Serial.printf("Received JSON: %s\n", json.c_str());
  DeserializationError error = deserializeJson(doc, json);
  
  if (error) {
    Serial.printf("JSON parse failed: %s\n", error.c_str());
    return false;
  }

  // 1. Sync Request
  if (doc["sy"]) {
    sendData(true);
    return true;
  }

  // 2. Status Updates (Sliders)
  if (JsonVariantConst status = doc["st"]) {
    if (status["f"].is<int>()) {
      flow = status["f"];
      drawSlider(sliders[0]);
    }
    if (status["a"].is<int>()) {
      angle = status["a"];
      drawSlider(sliders[2]);
    }
    if (status["s"].is<int>()) {
      speed = constrain(status["s"].as<int>(), 0, 30);
      stepsPerSec = map(speed, 0, 30, 0, 7000);
      drawSlider(sliders[1]);
    }
    updateMotorParameters();
  }

  // 3. Timer Control
  if (JsonVariantConst timer = doc["tm"]) {
    if (timer["run"].is<bool>()) {
      isRunning = timer["run"];
    }
    
  if (timer["tt"].is<int>()) totalSeconds = timer["tt"];
  if (timer["rm"].is<int>()) { 
    if(timer["ts"].is<long long>() && (millis() - lastSyncMillis) < SIX_HOURS_MS) {
      long long clientTs = timer["ts"];
      long long now = getEpochMillis();
      long long elapsed = now - clientTs;
      if(elapsed >= 0 && elapsed < 10000) {
        int adjustedRm = timer["rm"].as<int>() - (int)(elapsed / 1000);
        remainingSeconds = (adjustedRm > 0) ? adjustedRm : 0;
      } else {
        remainingSeconds = timer["rm"];
      }
    } else {
      remainingSeconds = timer["rm"];
    }
  }
    
    drawTimer();
  }

  JsonVariantConst wifi = doc["wf"];
  if (!wifi.isNull()) {
    if (wifi["id"] && wifi["pw"] && wifi["et"]) {
      initializeWifi(wifi["id"], wifi["pw"], strcmp(wifi["et"], "open") == 0);
    }
  }

  if (doc["inbuilt"].is<int>()) {
  uint8_t fluidIndex = doc["inbuilt"];
  if (fluidIndex < 3) {
    handleFluidButtonPress(fluidIndex);
    bitFlag |= FLAG_INBUILT;
    sendData();
  }
  }

  return true;
}

void onWsEvent(uint8_t num, WStype_t type, uint8_t * payload, size_t length) {
  switch (type) {
    case WStype_CONNECTED: {
      if(deviceConnected) { wsServer.disconnect(num); return; }
      deviceConnected = true;
      connectedID = num;
      MDNS.end();
      sendData(true);
      break;
    }
    case WStype_DISCONNECTED:
      deviceConnected = false;
      connectedID = -1;
      startAdvertisement();
      break;
    case WStype_TEXT:
    case WStype_BIN:
      updateFromJson(String((char*)payload, length));
      break;
    default: break;
  }
}

void initializeServer() {
  wsServer.begin();
  wsServer.onEvent(onWsEvent);
  Serial.println("WebSocket server started");
}

// ==================== TOUCH HANDLING ====================
void checkSliderTouch(int px, int py) {
  px = constrain(px, 0, tft.width() - 1);

  for (int i = 0; i < len(sliders); i++) {

    Slider s = sliders[i];

    if (py >= s.y && py <= s.y + s.h) {

      int newVal = map(px, s.x, s.x + s.w, 0, s.maxVal);
      newVal = constrain(newVal, 0, s.maxVal);

      if (*s.val != newVal) {

        if (i == 0) bitFlag |= FLAG_FLOW_CHANGED;
        if (i == 1) bitFlag |= FLAG_SPEED_CHANGED;
        if (i == 2) bitFlag |= FLAG_ANGLE_CHANGED;

        *s.val = newVal;
        drawSlider(s);
        updateMotorParameters();

        //  MOTOR 2 LOGIC
        if (i == 3) {
          int delta = newVal - lastMotor2Value;
//  LIMIT movement per interaction
if (delta > 2) delta = 2;
if (delta < -2) delta = -2;

if (delta != 0) {
  startMotor2Move(delta);
  lastMotor2Value += delta;   //  IMPORTANT (not = newVal)
}
        }

        sendData();
      }
    }
  }
}

void handleFluidButtonPress(int buttonIndex) {
  if (buttonIndex == 0) { flow = 10; speed = 10; angle = 10; }
  else if (buttonIndex == 1) { flow = 20; speed = 15; angle = 20; }
  else if (buttonIndex == 2) { flow = 25; speed = 20; angle = 30; }
  inbuiltFluidIndex = buttonIndex;

  for(int i = 0; i < len(fluidButtons); i++) {
    bool prev = fluidButtons[i].active;
    fluidButtons[i].active = (i == buttonIndex);
    if(prev != fluidButtons[i].active) {
      drawButton(fluidButtons[i],fluidButtons[i].active?TFT_ORANGE:TFT_DARKGREY);
    }
  }
  for (int i = 0; i < len(sliders); i++) drawSlider(sliders[i]);
  updateMotorParameters();
  bitFlag |= FLAG_FLOW_CHANGED | FLAG_ANGLE_CHANGED | FLAG_SPEED_CHANGED;
  sendData();
}

bool isPointInButton(int px, int py, const Button& btn) {
    unsigned long now = millis();
    bool inButton = (px >= btn.x && px <= btn.x + btn.w && py >= btn.y && py <= btn.y + btn.h);
    if (inButton && now - lastTouchTime > TAP_DEBOUNCE_MS) {
        lastTouchTime = now;
        return true;
    }
    return false;
}

void checkButtonTouch(int px, int py) {
  if (isPointInButton(px, py, startBtn)) {
    isRunning = true; stopFlag = false; bitFlag |= FLAG_TIMER;
    drawTimer(); sendData(); return;
  }
  if (isPointInButton(px, py, stopBtn)) {
    isRunning = false; stopFlag = true; bitFlag |= FLAG_TIMER;
    drawTimer(); sendData(); return;
  }
  for (int i = 0; i < 3; i++) {
    if (isPointInButton(px, py, fluidButtons[i])) {
      handleFluidButtonPress(i);
      return;
    }
  }
}

void handleTouchInput() {
  TS_Point p = ts.getPoint();

  int px = map(p.x, TS_MINX, TS_MAXX, 0, tft.width());
  int py = map(p.y, TS_MINY, TS_MAXY, 0, tft.height());

  checkSliderTouch(px, py);
  checkButtonTouch(px, py);
}

