void updateNTCTemp() {
  static unsigned long lastRead = 0;

  if (millis() - lastRead > 5000) {   // every 5 seconds
    ntcTemp = readNTCTemperature();
    lastRead = millis();
  }
}

void setup() {
  Serial.begin(115200);
  sensors.begin();
  pinMode(NTC_PIN, INPUT);
  sensors.setWaitForConversion(false);
sensors.requestTemperatures(); // start first conversion
  lastMotor2Value = motor2Rotation;
  delay(1000);
  initializePins();
  initializeDisplay();
  refreshAllUIElements();
  initializeWifi();
  syncTime();
  startAdvertisement();
  initializeServer();
  checkSketchSpace();
  drawTemperature();
  analogReadResolution(12);
  Serial.println("System Ready.");
}

void loop() {
  updateTimer();
  wsServer.loop();
  updateNTCTemp();
  runMotor2();
static float lastNTC = -100;

if (abs(ntcTemp - lastNTC) > 0.1) {
  drawNTCTemperature();
  lastNTC = ntcTemp;
}
  static unsigned long lastTouch = 0;

if (ts.touched() && millis() - lastTouch > 25) {
  handleTouchInput();
  lastTouch = millis();
}
  if (millis() - lastSyncMillis > syncInterval) {
    syncTime();
  }
  
  
  if (millis() - lastSync > DATA_SYNC_INTERVAL) {
    lastSync = millis();
    if (deviceConnected) {
      Serial.println("Performing Sync...");
      sendData(true); 
    }
  }
  
  static unsigned long lastBTTempSend = 0;
  if (millis() - lastBTTempSend > 2000) {
    lastBTTempSend = millis();
    bitFlag |= FLAG_TEMPERATURE;
    sendData(false);
  }

   controlHeater();

  static float lastTemp = -100;

if (abs(currentTemp - lastTemp) > 0.1) {
  drawTemperature();
  lastTemp = currentTemp;
}
  
 
  controlPumpByTemp();
  oscillateStepper();
}
